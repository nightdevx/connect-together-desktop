# Desktop -> Go backend base URL
CT_BACKEND_URL=http://127.0.0.1:4001

# LiveKit room name requested by desktop token flow
CT_LIVEKIT_ROOM=main-lobby

# Optional ICE configuration for WebRTC stack used by desktop media capture/connectivity
CT_ICE_URLS=stun:stun.l.google.com:19302
CT_ICE_USERNAME=
CT_ICE_CREDENTIAL=

# Legacy fallback keys (optional, keep empty unless needed)
# BACKEND_URL=
# LIVEKIT_DEFAULT_ROOM=
# DESKTOP_ICE_URLS=
# DESKTOP_ICE_USERNAME=
# DESKTOP_ICE_CREDENTIAL=
