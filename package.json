{
  "name": "connect-together-desktop",
  "version": "0.1.10",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nightdevx/connect-together-desktop.git"
  },
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"vite\" \"wait-on http-get://127.0.0.1:5173 file:dist/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 CT_ENV_FILE=.env.development electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "livekit-client": "^2.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.14.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.nightdijital.connecttogether.desktop",
    "productName": "Connect Together",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "tr"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "files": [
      "dist/**",
      "package.json",
      "!**/*.map",
      "!**/*.d.ts",
      "!**/tsconfig*.json",
      "!**/{test,tests,__tests__,example,examples,docs,doc}/**",
      "!**/.github/**",
      "!**/.vscode/**"
    ],
    "win": {
      "icon": "public/images/logo.ico",
      "artifactName": "Connect-Together-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "public/images/logo.ico",
      "uninstallerIcon": "public/images/logo.ico",
      "installerHeaderIcon": "public/images/logo.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nightdevx",
        "repo": "connect-together-desktop",
        "releaseType": "release"
      }
    ]
  }
}
